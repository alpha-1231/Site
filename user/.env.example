# Standalone user app environment file.
# Copy this file to .env.local for development or .env.production for deployment.
# Use a GitHub Raw folder root. Required when this app is deployed without the admin app.
VITE_PUBLIC_DATA_ROOT=https://raw.githubusercontent.com/<owner>/<data-repo>/<branch>
VITE_ADMIN_API_ORIGIN=http://localhost:3000
VITE_DEV_HOST=0.0.0.0
VITE_DEV_PORT=5173
# Use / for a domain-root deploy like https://aboutmyschool.com/
# Use /user/ only if the app is hosted at https://example.com/user/
VITE_USER_BASE=/
VITE_SITE_NAME=AboutMySchool
VITE_SITE_ORIGIN=https://aboutmyschool.com
